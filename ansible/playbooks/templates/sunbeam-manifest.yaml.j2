# Sunbeam single-node deployment manifest (Sunbeam 2024.1 / Ubuntu 24.04 noble)
# Passed to: sunbeam cluster bootstrap --manifest <this-file>
#
# Storage: MicroCeph is installed but receives zero OSDs. All persistent
# storage is served by ZFS over NFS (see 02-zfs.yml). Glance uses the local
# file backend; Cinder is unused.
#
# Network: management_cidr is intentionally omitted — Sunbeam auto-detects
# from the host's primary interface, which avoids interface-mask mismatches.

deployment:
  user:
    run_demo_setup: false

  # External (provider) network — a slice of your physical LAN allocated for
  # floating IPs. OVN creates an external bridge attached to this range.
  external_network:
    cidr: "{{ provider_network_cidr }}"
    gateway: "{{ provider_network_gateway }}"
    start: "{{ provider_network_pool_start }}"
    end: "{{ provider_network_pool_end }}"
    network_type: flat
    physical_network: physnet1

  dns:
    nameservers: "{{ nova_dns_servers | join(',') }}"

# Disable optional addons to conserve RAM
addons:
  observability:
    enabled: false
  cos:
    enabled: false
