# Sunbeam single-node deployment manifest (Sunbeam 2024.1 / Ubuntu 24.04 noble)
# Passed to: sunbeam cluster bootstrap --manifest <this-file>
#
# NOTE: 02-sunbeam.yml currently uses --accept-defaults without a manifest,
# which matches the official install guide and works reliably. This file is
# kept here in case a manifest is needed for customisation (e.g. non-default
# provider network settings in a future re-run).

deployment:
  bootstrap:
    management_cidr: "{{ management_cidr }}"

  user:
    run_demo_setup: false

  # External (provider) network — a slice of your physical LAN for floating IPs.
  external_network:
    cidr: "{{ provider_network_cidr }}"
    gateway: "{{ provider_network_gateway }}"
    start: "{{ provider_network_pool_start }}"
    end: "{{ provider_network_pool_end }}"
    network_type: flat
    physical_network: physnet1
