# Sunbeam single-node deployment manifest
# Passed to: sunbeam cluster bootstrap --manifest <this-file>
# Ref: https://canonical-microstack.readthedocs-hosted.com/
#
# Storage: MicroCeph is installed but receives zero OSDs.
# All persistent storage is served by ZFS over NFS (see 02-zfs.yml).
# Glance uses the local file backend; Cinder is unused.

bootstrap:
  # management_cidr must be the network CIDR (e.g. 172.16.0.0/24), not a host
  # address (172.16.0.7/24). Sunbeam uses this to find a matching interface
  # and subnet — a host-style CIDR fails interface discovery.
  management_cidr: "{{ provider_network_cidr }}"

# Provider network — a slice of your physical LAN allocated for floating IPs.
# OVN creates an external bridge attached to this range.
external_network:
  cidr: "{{ provider_network_cidr }}"
  gateway: "{{ provider_network_gateway }}"
  start: "{{ provider_network_pool_start }}"
  end: "{{ provider_network_pool_end }}"
  network_type: flat

dns:
  nameservers: "{{ nova_dns_servers | join(',') }}"

# Disable optional addons to conserve RAM (128GB is sufficient but not infinite)
addons:
  observability:
    enabled: false
  cos:
    enabled: false
